# Backend runs with mocked AI by default.
# To use real providers, create backend/.env and set AI_PROVIDER + the provider key.
# Supported: openai, gemini, anthropic
AI_PROVIDER=mock
PORT=3001

# --- OpenAI ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Gemini (Google AI Studio) ---
# AI_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic (Claude) ---
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_VERSION=2023-06-01
