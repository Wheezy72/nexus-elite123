# Backend runs with mocked AI by default.
# To use real providers, create backend/.env and set AI_PROVIDER + the provider key.
# Supported: openai, gemini
AI_PROVIDER=mock
PORT=3001

# --- OpenAI ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Gemini (Google AI Studio) ---
# AI_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
